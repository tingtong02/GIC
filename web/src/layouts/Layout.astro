---
import '../styles/global.css';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Add Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#F8FAFC] text-slate-800 antialiased selection:bg-slate-200 selection:text-slate-900">
    <!-- Sticky Nav -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200 shadow-sm">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="#hero" class="font-bold tracking-tight text-slate-900 hover:text-blue-600 transition-colors">
          GIC Research System
        </a>
        <ul class="flex gap-6 text-sm font-semibold text-slate-500 hidden md:flex">
           <li><a href="#motivation" class="hover:text-slate-900 transition-colors">研究动机</a></li>
           <li><a href="#blueprint" class="hover:text-slate-900 transition-colors">技术总览</a></li>
           <li><a href="#architecture" class="hover:text-slate-900 transition-colors">架构与取舍</a></li>
           <li><a href="#results" class="hover:text-slate-900 transition-colors">评估结果</a></li>
           <li><a href="#boundaries" class="hover:text-slate-900 transition-colors">边界与限制</a></li>
        </ul>
      </nav>
    </header>
    <slot />
    
    <footer class="border-t border-slate-200 bg-white py-16 mt-32">
       <div class="max-w-4xl mx-auto px-6 text-center text-sm text-slate-500 font-medium">
          Phase 8 • Frozen Default<br/>
          <span class="font-light mt-2 block">基于证据保守性准则架构。不作全面预测断言。</span>
       </div>
    </footer>
  </body>
</html>
